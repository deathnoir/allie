# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
FISH_API_KEY=your-fish-audio-api-key-here

# Optional: Fish Audio voice model (defaults to JARVIS MCU voice)
# FISH_VOICE_ID=612b878b113047d9a770c069c8b4fdfe

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Additional directories to scan for projects (comma-separated)
# JARVIS always scans Desktop. Add more folders here.
# PROJECT_DIRS=D:\Projects,D:\Allie,C:\Users\me\repos

# macOS only: Specific Apple Calendar accounts to read (comma-separated emails)
# If not set, JARVIS reads ALL calendars from Apple Calendar
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com

# Windows only: Google API for Calendar & Gmail
# 1. Create a Google Cloud project at https://console.cloud.google.com/
# 2. Enable "Google Calendar API" and "Gmail API"
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download the JSON and save as data/google_credentials.json
# 5. Run: python -m jarvis_platform.google_auth
